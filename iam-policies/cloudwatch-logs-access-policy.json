{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowDatabricksClusterLogging",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogGroups",
        "logs:DescribeLogStreams"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:123456789012:log-group:/aws/databricks/*"
      ]
    },
    {
      "Sid": "DenyLogTampering",
      "Effect": "Deny",
      "Action": [
        "logs:DeleteLogGroup",
        "logs:DeleteLogStream",
        "logs:DeleteRetentionPolicy"
      ],
      "Resource": "*"
    }
  ]
}
